.venv/
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
terraform.tfstate.d/
packer_cache/
*.log
*.eval

# Built artifacts -- live under /mnt/vm-storage/cyber-range and should
# never be committed in any case, but guard against accidental copies.
# Anchored to repo root so they don't shadow unrelated dirs like
# docs/website/src/assets/images/.
/images/
/isos/
*.qcow2
*.img
*.iso

# Secrets
secrets/
*.kdbx
*.ovpn
*.pem
*.key

# CredService build outputs + per-run constants (regenerated by
# scripts/seed_credservice.py during make m6-bake)
re_bait/CredService/Constants.g.cs
re_bait/CredService/bin/
re_bait/CredService/obj/

__pycache__/
*.pyc
*.pyo
*.pyd
*.swp
# Vendored attacker-tool binaries (fetch separately; baked into the kali-tools
# image at build time and scp-ed to kali by the smokes). Not tracked.
scripts/bin/*.exe
