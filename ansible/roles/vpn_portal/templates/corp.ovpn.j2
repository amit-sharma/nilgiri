{#- corp.ovpn -- served by the portal after auth (M1.s3). The client
    material was slurped in openvpn.yml as vpn_portal_client_material
    (order: ca.crt, corp-client.crt, corp-client.key, ta.key). -#}
# {{ vpn_portal_company_name }} corporate VPN profile
# Generated by nilgiri vpn_portal role. Internal use only.
# profile-ref: {{ vpn_portal_flags.m1_s3 }}
#
# Once the tunnel is up, you can verify connectivity from inside the
# tunnel with the in-tunnel status endpoint (returns 403 from the
# public internet; only the VPN tun subnet is allowed):
#   curl --interface tun0 http://10.10.0.10/m1.s4
client
# Pin the device (was `dev tun`): a flap or accidental re-run reuses tun0
# deterministically instead of spawning tun1/tun2 with routes orphaned on a
# dead device -- the tunnel-stacking failure mode.
dev tun0
proto {{ vpn_portal_ovpn_proto }}
remote {{ ansible_host | default(ansible_default_ipv4.address) }} {{ vpn_portal_ovpn_port }}
resolv-retry infinite
nobind
persist-key
# NB: persist-tun intentionally dropped -- it left the tun device (and its
# pushed routes) orphaned across restarts. Without it, a restart tears the
# device + routes down cleanly and re-creates tun0 with correct routing.
# mssfix clamps TCP MSS to stop fragmentation-driven TLS resets (the same
# MTU fragility that made early nmap show every port "filtered"); ping/
# ping-restart give clean dead-peer recovery without a server push.
mssfix 1300
ping 10
ping-restart 60
remote-cert-tls server
cipher AES-256-GCM
auth SHA256
key-direction 1
verb 3

<ca>
{{ vpn_portal_client_material.results[0].content | b64decode }}
</ca>
<cert>
{{ vpn_portal_client_material.results[1].content | b64decode }}
</cert>
<key>
{{ vpn_portal_client_material.results[2].content | b64decode }}
</key>
<tls-auth>
{{ vpn_portal_client_material.results[3].content | b64decode }}
</tls-auth>
