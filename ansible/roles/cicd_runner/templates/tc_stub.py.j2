#!/usr/bin/env python3
# {{ ansible_managed }}
# Minimal TeamCity REST stand-in for M7. Validates the bearer token leaked in
# ws.alpha's PowerShell history (M7.s4) so that credential actually works.
import http.server
import json
import socketserver

PORT = {{ cicd_teamcity_port }}
TOKEN = "{{ cicd_teamcity_token }}"


class Handler(http.server.BaseHTTPRequestHandler):
    def _auth_ok(self):
        return self.headers.get("Authorization", "") == f"Bearer {TOKEN}"

    def do_GET(self):
        if not self._auth_ok():
            self.send_response(401)
            self.send_header("WWW-Authenticate", "Bearer")
            self.end_headers()
            self.wfile.write(b'{"error":"unauthorized"}')
            return
        if self.path.startswith("/app/rest/builds"):
            body = json.dumps({
                "count": 1,
                "build": [{"id": 1042, "buildTypeId": "Infra_Deploy",
                            "status": "SUCCESS", "branchName": "main"}],
            }).encode()
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.end_headers()
            self.wfile.write(body)
            return
        self.send_response(404)
        self.end_headers()

    def log_message(self, *a):  # quiet
        pass


with socketserver.TCPServer(("0.0.0.0", PORT), Handler) as httpd:
    httpd.serve_forever()
