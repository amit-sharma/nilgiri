---
import { Icon } from 'astro-icon/components';

interface ToolCall {
  tool: 'bash' | 'python';
  command: string;
  output?: string;
}

interface Props {
  index: number;
  total: number;
  title: string;
  reasoning: string;
  calls: readonly ToolCall[];
  flag?: string;
}

const { index, total, title, reasoning, calls, flag } = Astro.props as Props;
---

<div class="mb-10">
  <div class="mb-3 flex items-center gap-3">
    <span
      class="flex h-8 w-8 flex-none items-center justify-center rounded-full bg-primary text-sm font-bold text-white"
    >
      {index}
    </span>
    <h3 class="text-lg font-bold text-heading">{title}</h3>
    <span class="text-xs text-muted">Step {index} of {total}</span>
  </div>

  <div class="ml-11 space-y-px">
    <div class="rounded-md border-l-4 border-gray-300 bg-gray-50 p-3 dark:border-slate-500 dark:bg-slate-800/60">
      <div class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-muted">
        <Icon name="tabler:message-circle" class="h-3.5 w-3.5" />
        Reasoning
      </div>
      <p class="text-sm italic text-default">{reasoning}</p>
    </div>

    {
      calls.map((call) => (
        <>
          <div class="border-l-4 border-primary bg-slate-900 p-3">
            <div class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-cyan-300">
              <Icon name="tabler:terminal-2" class="h-3.5 w-3.5" />
              Tool call: {call.tool}
            </div>
            <pre class="overflow-x-auto text-xs text-cyan-50">
              <code>{call.command}</code>
            </pre>
          </div>
          {call.output && (
            <div class="border-l-4 border-slate-700 bg-slate-950 p-3">
              <div class="mb-1 flex items-center gap-1.5 text-xs font-semibold uppercase tracking-wide text-slate-500">
                <Icon name="tabler:arrow-back-up" class="h-3.5 w-3.5" />
                Output
              </div>
              <pre class="overflow-x-auto text-xs text-slate-400">
                <code>{call.output}</code>
              </pre>
            </div>
          )}
        </>
      ))
    }

    {
      flag && (
        <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-green-600/15 px-3 py-1 text-xs font-medium text-green-500 dark:text-green-400">
          <Icon name="tabler:flag-check" class="h-3.5 w-3.5" />
          Flag captured: <code>{flag}</code>
        </div>
      )
    }
  </div>
</div>
